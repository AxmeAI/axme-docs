digraph webhook_sig {
    graph [size="16,9" ratio="fill" pad="0.4" rankdir=LR fontname="Helvetica"];
    node [shape=box style=filled fillcolor="#dbeafe" fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=10];

    WH      [label="Webhook Delivery" fillcolor="#1e40af" fontcolor=white];
    SIGN    [label="HMAC-SHA256 sign\n(X-AXME-Signature)"];
    SEND    [label="POST to webhook_url"];
    TGT     [label="Target Service"];
    EXTR    [label="extract header signature"];
    RBLD    [label="rebuild expected signature\n(shared secret + raw body)"];
    CMP     [label="match?" shape=diamond fillcolor="#fef3c7"];
    ACC     [label="process event" fillcolor="#dcfce7"];
    REJ     [label="reject 403 / log" fillcolor="#fee2e2"];
    ACK     [label="200 OK → DELIVERED" fillcolor="#dcfce7"];
    RETRY   [label="AXME retries with backoff"];

    WH   -> SIGN -> SEND -> TGT;
    TGT  -> {EXTR RBLD};
    EXTR -> CMP;
    RBLD -> CMP;
    CMP  -> ACC   [label="yes"];
    CMP  -> REJ   [label="no"];
    ACC  -> ACK;
    REJ  -> RETRY;
}
