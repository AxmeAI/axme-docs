digraph secrets_rotation {
    graph [size="16,9" ratio="fill" pad="0.4" rankdir=LR fontname="Helvetica"];
    node [shape=box style=filled fillcolor="#dbeafe" fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=10];

    STORE  [label="Secrets Store\n(Vault / KMS)" fillcolor="#1e40af" fontcolor=white];
    INJ    [label="inject at boot\n(env / sidecar)"];
    SVC    [label="Service Runtime" fillcolor="#dcfce7"];
    USE    [label="use secret"];
    SCHED  [label="rotation scheduler"];
    NEWV   [label="generate new version"];
    GRACE  [label="dual-version grace period"];
    REV    [label="revoke old version" fillcolor="#fee2e2"];
    AUD    [label="audit: rotation event"];
    DET    [label="leak detection" fillcolor="#fef3c7"];
    ALERT  [label="alert + emergency revoke" fillcolor="#fee2e2"];

    STORE -> INJ -> SVC -> USE;
    STORE -> SCHED -> NEWV -> GRACE -> REV -> AUD;
    STORE -> DET -> ALERT;
}
