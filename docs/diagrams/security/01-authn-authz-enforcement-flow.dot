digraph authn_authz {
    graph [size="16,9" ratio="fill" pad="0.4"];
    rankdir=LR
    node [shape=box fontname="monospace" fontsize=11]
    edge [fontname="monospace" fontsize=10]

    REQ   [label="Incoming Request"]
    AKEY  [label="Validate machine key\nx-api-key (AXME_API_KEY)"]
    F401A [label="401 missing/invalid\nx-api-key" style=filled fillcolor=lightyellow]
    BRTE  [label="Actor token required\non route?" shape=diamond]
    VJWT  [label="Validate actor token\nJWT sig + claims + scope"]
    F401B [label="401/403 missing actor token\nor invalid actor scope" style=filled fillcolor=lightyellow]
    OWNR  [label="Owner scope\nchecks"]
    F403A [label="403 owner mismatch" style=filled fillcolor=lightyellow]
    ROLE  [label="Role or delegated\ngrant allows action?" shape=diamond]
    F403B [label="403 forbidden" style=filled fillcolor=lightyellow]
    EXEC  [label="Execute endpoint logic"]
    AUDIT [label="Emit audit\n+ trace metadata" style=filled fillcolor=lightgreen]

    REQ   -> AKEY
    AKEY  -> F401A [label="fail"]
    AKEY  -> BRTE  [label="ok"]
    BRTE  -> VJWT  [label="yes"]
    BRTE  -> OWNR  [label="no"]
    VJWT  -> F401B [label="fail"]
    VJWT  -> OWNR  [label="ok"]
    OWNR  -> F403A [label="fail"]
    OWNR  -> ROLE  [label="ok"]
    ROLE  -> F403B [label="deny"]
    ROLE  -> EXEC  [label="allow"]
    EXEC  -> AUDIT
}
