digraph human_loop {
    graph [size="16,9" ratio="fill" pad="0.4" rankdir=LR fontname="Helvetica"];
    node [shape=box style=filled fillcolor="#dbeafe" fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=10];

    INT   [label="Intent: IN_PROGRESS" fillcolor="#1e40af" fontcolor=white];
    NEED  [label="approval needed?" shape=diamond fillcolor="#fef3c7"];
    EXEC  [label="execute"];
    WAIT  [label="WAITING_FOR_HUMAN" fillcolor="#fef3c7"];
    INBOX [label="Approver Inbox"];
    DEC   [label="decision" shape=diamond fillcolor="#fef3c7"];
    RES   [label="resume intent"];
    CAN   [label="CANCELED" fillcolor="#fee2e2"];
    TOUT  [label="WAITING_FOR_TIME\n→ timeout" fillcolor="#fef3c7"];
    DONE  [label="COMPLETED" fillcolor="#dcfce7"];

    INT  -> NEED;
    NEED -> EXEC  [label="no"];
    NEED -> WAIT  [label="yes"];
    WAIT -> INBOX -> DEC;
    DEC  -> RES   [label="approve"];
    DEC  -> CAN   [label="reject"];
    DEC  -> TOUT  [label="timeout"];
    RES  -> EXEC -> DONE;
    TOUT -> CAN;
}
