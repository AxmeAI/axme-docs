digraph access_control {
    graph [size="16,9" ratio="fill" pad="0.4"];
    rankdir=LR
    node [shape=box fontname="monospace" fontsize=11]
    edge [fontname="monospace" fontsize=10]

    CALL  [label="Caller\nAPI request"]
    IKEY  [label="Validate\nx-api-key"]
    F401A [label="401 invalid api key" style=filled fillcolor=lightyellow]
    BRTE  [label="Bearer required\non this route?" shape=diamond]
    VJWT  [label="Validate JWT\nsignature+claims+scope"]
    F401B [label="401/403 token invalid\nor scope mismatch" style=filled fillcolor=lightyellow]
    OWNR  [label="owner scope\nchecks"]
    F403A [label="403 owner mismatch" style=filled fillcolor=lightyellow]
    ROLE  [label="role or delegated\ngrant allows action?" shape=diamond]
    F403B [label="403 forbidden" style=filled fillcolor=lightyellow]
    EXEC  [label="Execute\nendpoint logic"]
    MUT   [label="mutation request?" shape=diamond]
    CAS   [label="CAS: generation\nmatches?" shape=diamond]
    F409  [label="409 conflict\n(stale writer)" style=filled fillcolor=lightyellow]
    APPLY [label="apply mutation\ngeneration++" style=filled fillcolor=lightgreen]
    READ  [label="return\nread result" style=filled fillcolor=lightgreen]
    AUDIT [label="emit audit\n+ trace event"]

    CALL  -> IKEY
    IKEY  -> F401A [label="fail"]
    IKEY  -> BRTE  [label="ok"]
    BRTE  -> VJWT  [label="yes"]
    BRTE  -> OWNR  [label="no"]
    VJWT  -> F401B [label="fail"]
    VJWT  -> OWNR  [label="ok"]
    OWNR  -> F403A [label="fail"]
    OWNR  -> ROLE  [label="ok"]
    ROLE  -> F403B [label="deny"]
    ROLE  -> EXEC  [label="allow"]
    EXEC  -> MUT
    MUT   -> READ  [label="read"]
    MUT   -> CAS   [label="mutation"]
    CAS   -> F409  [label="mismatch"]
    CAS   -> APPLY [label="match"]
    READ  -> AUDIT
    APPLY -> AUDIT
}
