digraph resume_policy {
    graph [size="16,9" ratio="fill" pad="0.4" rankdir=LR fontname="Helvetica"];
    node [shape=box style=filled fillcolor="#dbeafe" fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=10];

    INT   [label="Intent: WAITING" fillcolor="#1e40af" fontcolor=white];
    RES   [label="POST /intents/:id/resume"];
    CTRL  [label="PATCH /intents/:id/controls"];
    POL   [label="PATCH /intents/:id/policy"];
    GATE  [label="policy grants\nallow resume?" shape=diamond fillcolor="#fef3c7"];
    CASC  [label="policy_generation\nmatches?" shape=diamond fillcolor="#fef3c7"];
    EXEC  [label="resume execution" fillcolor="#dcfce7"];
    DENY  [label="403 Forbidden" fillcolor="#fee2e2"];
    APPLY [label="apply delta" fillcolor="#dcfce7"];
    CONF  [label="409 Conflict\n(retry with fresh generation)" fillcolor="#fee2e2"];

    INT  -> {RES CTRL POL};
    RES  -> GATE;
    CTRL -> CASC;
    POL  -> CASC;
    GATE -> EXEC [label="yes"];
    GATE -> DENY [label="no"];
    CASC -> APPLY [label="yes"];
    CASC -> CONF  [label="no"];
    APPLY -> EXEC;
}
