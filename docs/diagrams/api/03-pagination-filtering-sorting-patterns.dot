digraph pagination {
    graph [size="16,9" ratio="fill" pad="0.4" rankdir=LR fontname="Helvetica"];
    node [shape=box style=filled fillcolor="#dbeafe" fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=10];

    REQ    [label="API Request" fillcolor="#1e40af" fontcolor=white];
    PAGE   [label="paginated?" shape=diamond fillcolor="#fef3c7"];
    CUR    [label="cursor-based pagination\n(next_cursor / prev_cursor)"];
    FULL   [label="full response"];
    FIL    [label="filters: field=value\n(eq / lt / gt / in / contains)"];
    SRT    [label="sort: field:asc / field:desc"];
    RESP   [label="response: items + cursors" fillcolor="#dcfce7"];

    REQ  -> {PAGE FIL SRT};
    PAGE -> CUR  [label="yes"];
    PAGE -> FULL [label="no"];
    CUR  -> RESP;
    FULL -> RESP;
    FIL  -> RESP;
    SRT  -> RESP;
}
