digraph rate_limit {
    graph [size="16,9" ratio="fill" pad="0.4" rankdir=LR fontname="Helvetica"];
    node [shape=box style=filled fillcolor="#dbeafe" fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=10];

    REQ    [label="API Request" fillcolor="#1e40af" fontcolor=white];
    CHK    [label="rate limit check" shape=diamond fillcolor="#fef3c7"];
    ALLOW  [label="process request" fillcolor="#dcfce7"];
    DENY   [label="429 Too Many Requests\n(Retry-After header)" fillcolor="#fee2e2"];
    RESP   [label="response" fillcolor="#dcfce7"];
    CLI    [label="client backs off"];
    DED    [label="deduct from quota bucket"];
    REF    [label="sliding window refill"];

    REQ   -> CHK;
    CHK   -> ALLOW [label="within quota"];
    CHK   -> DENY  [label="exceeded"];
    ALLOW -> RESP;
    ALLOW -> DED -> REF;
    DENY  -> CLI -> REQ;
}
