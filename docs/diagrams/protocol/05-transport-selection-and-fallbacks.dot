digraph transport {
    graph [size="16,9" ratio="fill" pad="0.4" rankdir=LR fontname="Helvetica"];
    node [shape=box style=filled fillcolor="#dbeafe" fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=10];

    SRC   [label="Sender Service" fillcolor="#1e40af" fontcolor=white];
    SEL   [label="transport selection" shape=diamond fillcolor="#fef3c7"];
    HTTPS [label="HTTPS / REST"];
    WS    [label="WebSocket"];
    QUEUE [label="Message Queue"];
    GW    [label="API Gateway" fillcolor="#e0e7ff"];
    OK    [label="delivered?" shape=diamond fillcolor="#fef3c7"];
    DONE  [label="success" fillcolor="#dcfce7"];
    FB    [label="fallback to QUEUE"];
    RETRY [label="retry with backoff"];

    SRC   -> SEL;
    SEL   -> HTTPS [label="primary"];
    SEL   -> WS    [label="streaming"];
    SEL   -> QUEUE [label="async"];
    HTTPS -> GW;
    WS    -> GW;
    QUEUE -> GW;
    GW    -> OK;
    OK    -> DONE [label="yes"];
    OK    -> FB   [label="timeout / disconnect"];
    FB    -> RETRY -> DONE;
}
