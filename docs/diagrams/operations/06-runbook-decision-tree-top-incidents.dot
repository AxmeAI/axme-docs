digraph runbook {
    graph [size="16,9" ratio="fill" pad="0.4" rankdir=LR fontname="Helvetica"];
    node [shape=box style=filled fillcolor="#dbeafe" fontname="Helvetica" fontsize=11];
    edge [fontname="Helvetica" fontsize=10];

    INC  [label="Incident" fillcolor="#1e40af" fontcolor=white];
    Q1   [label="service down?" shape=diamond fillcolor="#fef3c7"];
    Q2   [label="latency spike?" shape=diamond fillcolor="#fef3c7"];
    Q3   [label="error rate spike?" shape=diamond fillcolor="#fef3c7"];
    RB   [label="check last deploy\n(rollback if recent)"];
    DB   [label="check DB query plans\n+ connection pool"];
    LOG  [label="check logs: 5xx patterns"];
    ESC  [label="escalate to senior eng" fillcolor="#fef3c7"];
    RES  [label="resolve" fillcolor="#dcfce7"];
    PIR  [label="post-incident review"];

    INC -> Q1;
    Q1  -> RB  [label="yes"];
    Q1  -> Q2  [label="no"];
    Q2  -> DB  [label="yes"];
    Q2  -> Q3  [label="no"];
    Q3  -> LOG [label="yes"];
    Q3  -> ESC [label="no"];
    RB  -> RES;
    DB  -> RES;
    LOG -> RES;
    RES -> PIR;
}
